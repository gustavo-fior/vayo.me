{
  "manifest_version": 3,
  "name": "VAYØ",
  "version": "2.1.1",
  "description": "Save images, videos, and bookmarks to your VAYØ folders.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "https://vayo.me/*",
    "https://www.vayo.me/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://cdn.syndication.twimg.com/*",
    "https://pbs.twimg.com/*",
    "https://video.twimg.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["dist/content/x-tweet.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  }
}
